<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dimple's Nail Salon ✨</title>
  <link rel="stylesheet" href="style.css">
