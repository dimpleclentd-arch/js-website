  <div class="content hidden" id="exercise1">
    <h2>Exercise 1</h2>
    <p>Basic HTML with header, menu bar, slide menu, content, and footer.</p>
  </div>

  <div class="content hidden" id="exercise2">
    <h2>Exercise 2</h2>
    <ul>
      <li>Activity 1: First JavaScript Output</li>
      <li>Activity 2: Variables and Data Types</li>
      <li>Activity 3: Simple Calculator</li>
      <li>Activity 4: User Input</li>
      <li>Activity 5: Conditional Statements</li>
      <li>Activity 6: Loops</li>
      <li>Activity 7: JS & HTML Interaction</li>
    </ul>
