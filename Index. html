<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ITE 6 - website ✨</title>
  <link rel="stylesheet" href="style.css">
  <script src="script.js" defer></script>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <h1>ITE 6 - website ✨</h1>
  </div>

  <!-- Menu Bar -->
  <div class="menu-bar">
    <a href="#" onclick="showSection('home')">Home</a>
    <a href="#" onclick="showSection('about')">About</a>
    <a href="#" onclick="showSection('contact')">Contact</a>
  </div>

  <!-- Slide Menu -->
  <div class="slide-menu">
    <h3>Activities</h3>
    <ul>
      <li><a href="#" onclick="showSection('activity1')">Activity 1: Output</a></li>
      <li><a href="#" onclick="showSection('activity2')">Activity 2: Variables</a></li>
      <li><a href="#" onclick="showSection('activity3')">Activity 3: Calculator</a></li>
      <li><a href="#" onclick="showSection('activity4')">Activity 4: User Input</a></li>
      <li><a href="#" onclick="showSection('activity5')">Activity 5: Conditional</a></li>
      <li><a href="#" onclick="showSection('activity6')">Activity 6: Loops</a></li>
      <li><a href="#" onclick="showSection('activity7')">Activity 7: Button</a></li>
    </ul>
  </div>

  <!-- Sections -->
  <div class="content" id="homeSection">
    <h2>Welcome Home</h2>
    <p>This is the home section of the website.</p>
  </div>

  <div class="content" id="aboutSection" style="display:none;">
    <h2>About the Website</h2>
    <input type="text" id="aboutInput" class="sparkle-input">
  </div>

  <div class="content" id="contactSection" style="display:none;">
    <h2>Contact Us</h2>
    <p>Email: sparkle@example.com</p>
    <p>Phone: 123-456-7890</p>
  </div>

  <!-- Activity Sections -->
  <div class="content" id="activity1" style="display:none;">
    <h2>Activity 1: Output</h2>
    <p>Shows an alert and console message.</p>
  </div>

  <div class="content" id="activity2" style="display:none;">
    <h2>Activity 2: Variables</h2>
    <p>Check the console for variable values.</p>
  </div>

  <div class="content" id="activity3" style="display:none;">
    <h2>Activity 3: Calculator</h2>
    <p>Results are displayed in the console.</p>
  </div>

  <div class="content" id="activity4" style="display:none;">
    <h2>Activity 4: User Input</h2>
    <p>Prompts ask for your name and favorite number.</p>
  </div>

  <div class="content" id="activity5" style="display:none;">
    <h2>Activity 5: Conditional</h2>
    <p>Prompts check your age eligibility.</p>
  </div>

  <div class="content" id="activity6" style="display:none;">
    <h2>Activity 6: Loops</h2>
    <p>Numbers 1–10 and 10–1 are shown in the console.</p>
  </div>

  <div class="content" id="activity7" style="display:none;">
    <h2>Activity 7: Button</h2>
    <button id="activityButton">Click Me</button>
  </div>

  <!-- Footer -->
  <div class="footer">
    <p>&copy; ITE 6 - website ✨</p>
  </div>
</body>
</html>
