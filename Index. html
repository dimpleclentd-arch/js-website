    <ul>
      <li>Activity 1: Change Background Color</li>
      <li>Activity 2: Dark Mode Toggle</li>
      <li>Activity 3: Add List Items</li>
      <li>Activity 4: Remove Paragraph</li>
      <li>Activity 5: Character Counter</li>
      <li>Activity 6: Addition Calculator</li>
      <li>Activity 7: Change Image</li>
      <li>Activity 8: Mini To-Do List</li>
    </ul>
