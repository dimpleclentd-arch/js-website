    <a href="#" onclick="showSection('about')">About</a>
    <a href="#" onclick="showSection('contact')">Contact</a>
  </div>

  <!-- Slide Menu -->
  <div class="slide-menu">
    <h3>Exercises</h3>
    <ul>
      <li><a href="#" onclick="showSection('exercise1')">Exercise 1: Basic HTML</a></li>
      <li><a href="#" onclick="showSection('exercise2')">Exercise 2: JS Hands-On</a></li>
      <li><a href="#" onclick="showSection('exercise3')">Exercise 3: Interactive Tasks</a></li>
